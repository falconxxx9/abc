import requests
from bs4 import BeautifulSoup
print("Abuzar Ansari")
print("All libraries are imported")

def check_word_in_webpage(url, word):
    response = requests.get(url)

    if response.status_code == 200:
        soup = BeautifulSoup(response.content, 'html.parser')
        text_content = soup.get_text()

        if word.lower() in text_content.lower():
            print(f"The word '{word}' is present in webpage")
        else:
            print(f"The word '{word}' is NOT present in webpage")
    else:
        print("Failed to retrieve webpage")

print("Abuzar Ansari")
print("=================================")

url = input("Enter URL for Web Scraping: ")
word = input("Enter the word to check for: ")

check_word_in_webpage(url, word)


