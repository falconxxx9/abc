import pandas as pd
import matplotlib.pyplot as plt

# Create dataset
data = {
    "Month": ["Jan", "Feb", "Mar", "Apr", "May", "Jun"],
    "Sales": [12000, 10000, 18000, 17000, 20000, 22000]
}

df = pd.DataFrame(data)

# Line Chart: Sales Trend
plt.figure()

plt.plot(df["Month"], df["Sales"])

plt.xlabel("Month")
plt.ylabel("Sales")
plt.title("Abuzar Ansari: Monthly Sales Trend")

plt.show()




plt.figure()

plt.bar(df["Month"], df["Sales"])

plt.xlabel("Month")
plt.ylabel("Sales")
plt.title("Abuzar Ansari: Monthly Sales Comparison")

plt.show()


plt.figure()

plt.pie(df["Sales"], labels=df["Month"], autopct='%1.1f%%')

plt.title("Abuzar Ansari: Sales Distribution by Month")

plt.show()


